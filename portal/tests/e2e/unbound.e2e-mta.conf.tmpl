# Unbound config for the e2e-mta overlay.
#
# Overlaid via bind mount onto /usr/local/share/mta-templates/unbound.conf.tmpl.
# The entrypoint renders every template through string.Template.substitute(),
# so this file must escape every literal dollar sign by doubling it ($$ -> $$).
# Apart from that constraint, the body passes through unchanged.
#
# Why we override: the production Unbound config recurses to root nameservers,
# which CI runners cannot reach. Worse, postfix's reject_unknown_sender_domain
# (smtpd_sender_restrictions) queries the sender's domain on every MAIL FROM;
# without an answer for postern.test, the portal's submissions are deferred
# with 4xx and no mail reaches mailpit.
#
# This config:
# - Declares postern.test and elsewhere.test authoritatively (MX + A records
#   pointing at the IPAM-pinned mailpit IP).
# - Sets local-zone "." static, which makes every query OUTSIDE the local-data
#   zones return NXDOMAIN cleanly. mta-sts-resolver caches that as "no policy"
#   and postfix proceeds with smtp_tls_security_level falling back to may.
#
# DNSSEC is intentionally disabled: tests don't validate signatures, and the
# entrypoint runs with MTA_REQUIRE_DNSSEC=false.

server:
  interface: 127.0.0.1
  port: 53
  do-ip4: yes
  do-ip6: no
  do-udp: yes
  do-tcp: yes
  access-control: 127.0.0.0/8 allow
  hide-identity: yes
  hide-version: yes
  username: ""
  chroot: ""
  directory: "/etc/unbound"
  pidfile: "/var/run/unbound.pid"
  logfile: ""
  use-syslog: no

  # No upstream nameservers; Unbound is strictly authoritative for the local zones.
  local-zone: "." static

  # postern.test (the sending domain) -- needs MX so reject_unknown_sender_domain passes.
  local-data: "postern.test. IN MX 10 mail.postern.test."
  local-data: "postern.test. IN A 172.30.99.10"
  local-data: "mail.postern.test. IN A 172.30.99.10"
  local-data: "mta-sts.postern.test. IN A 172.30.99.10"

  # elsewhere.test (the admin's domain in MTA_ADMIN_EMAIL).
  local-data: "elsewhere.test. IN MX 10 mail.elsewhere.test."
  local-data: "elsewhere.test. IN A 172.30.99.10"
  local-data: "mail.elsewhere.test. IN A 172.30.99.10"
