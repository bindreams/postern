# Compose profiles: built-in MTA on by default. Comment to opt out and set
# SMTP_HOST below to a third-party relay (Resend, SES, Mailgun, etc.).
# NOTE: profiles must be set here in .env — a CLI-only `docker compose
# --profile` flag is not visible to the provisioner container.
COMPOSE_PROFILES=with-mta

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# (The portal refuses to start if this is left as the placeholder.)
SECRET_KEY=REPLACE_WITH_HEX_STRING

# SMTP target. Default points at the built-in mta service via its `mta-submit`
# network alias -- the bare `mta` name is multi-homed and resolves to the
# default network, whose source IP is outside Postfix's mynetworks, so
# submission would be rejected (see docs/deployment/email.md). To use a third-party relay,
# comment COMPOSE_PROFILES above and set the variables below to your provider.
SMTP_HOST=mta-submit
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Postern VPN <noreply@postern.example.com>

# Uncomment when re-hosting to a different domain; overrides the default in settings.py
# DOMAIN=postern.example.com

# Reverse-proxy / gateway (optional) -- see docs/deployment/gateway.md.
# Set ONLY when a TLS-passthrough proxy (e.g. Traefik) fronts nginx and you are
# NOT using compose.gateway.yaml (which sets a safe default for you). Value is
# the CIDR(s) allowed to send PROXY protocol v2; comma/space-separated.
# WARNING: setting this without a PROXY-v2-sending proxy in front makes nginx
# drop all :443 connections (browsers cannot speak PROXY protocol). Only set it
# when nginx's :443 is unreachable except through that trusted proxy (host ports
# stripped or firewalled) -- otherwise anyone who can reach :443 can forge a
# PROXY header and spoof their source IP.
# PROXY_PROTOCOL_FROM=172.20.0.0/16,fd00::/8

# Cosmetic display name shown in UI page titles, the OTP-email subject ("Your $PRODUCT_NAME
# login code"), and the downloaded-config filename prefix ("$product_name-<label>.json").
# Decoupled from DOMAIN and from MTA_DKIM_SELECTOR_PREFIX (the base for <base>1/<base>2 DKIM
# selectors, defaulting to "s").
# PRODUCT_NAME=Postern

# Frontend (optional) -- see docs/deployment/customization.md
# Custom brand icon path inside the portal container (SVG preferred, PNG accepted; <= 256 KB).
# Bind-mount the file read-only at this path. Unset/missing/oversized -> built-in default served.
# PRODUCT_ICON_PATH=/brand/icon.svg
# Directory inside the portal container holding GeoLite2-City.mmdb + GeoLite2-ASN.mmdb. Enables
# the login-page identity card's flag/city/ISP/ASN columns. Unset -> IP-only.
# GEOIP_DB_DIR=/geoip

# Built-in MTA refuses to start if required DNS records are missing or wrong.
# Set to false in dev / CI only.
MTA_VERIFY_DNS=true

# REQUIRED in production: technical reports (postmaster, abuse, tls-rpt, bounces)
# are forwarded here. Use a real mailbox you read (Proton, Fastmail, etc.).
# Postern does not host an inbox.
MTA_ADMIN_EMAIL=

# DNSSEC enforcement on the sending domain. Set to:
#   auto  (default) -- probe at startup. If the domain is DNSSEC-signed,
#                      mta refuses to start when the AD bit is missing.
#                      If the domain is unsigned, the check is skipped.
#                      Either way Unbound still validates at runtime for DANE.
#   true             -- always require. mta refuses to start without DNSSEC,
#                      even on unsigned domains. Use for fail-closed production.
#   false            -- skip the startup check entirely. Use only for dev/CI.
MTA_REQUIRE_DNSSEC=auto

# DKIM rotation runs in the separate `provisioner` container, isolated from the
# public-facing mta. Set DNS_PROVIDER to a libdns provider name (cloudflare,
# route53, gandi, digitalocean, ovh, hetzner, linode, namecheap) plus that
# provider's native env vars below to enable automatic rotation. Leave as "none"
# for manual rotation only -- in that case the provisioner generates the initial
# DKIM keypair on first start, then exits cleanly.
MTA_DKIM_ROTATION_DAYS=180
DNS_PROVIDER=none
# Provider-specific credentials -- pick the set matching DNS_PROVIDER above.
# CLOUDFLARE_API_TOKEN=
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# GANDI_API_TOKEN=
# DO_AUTH_TOKEN=

# ---------------- TLS cert auto-renewal (ACME DNS-01) ----------------
#
# Postern can renew its own TLS cert via Lego against your DNS provider's API.
# Issues a single cert covering <DOMAIN> and *.<DOMAIN> as SANs; one cert
# serves the portal, the MTA-STS subdomain, and Postfix on `mail.`. The
# wildcard avoids leaking subdomain enumeration via Certificate Transparency
# logs (only <DOMAIN> itself is publicly logged).
#
# To enable: set the values below AND replace the COMPOSE_PROFILES /
# COMPOSE_FILE lines at the top of this file with:
#
#   COMPOSE_FILE=compose.yaml:compose.cert.yaml
#   COMPOSE_PROFILES=with-mta,with-cert-renewal     (drop with-mta if not using built-in MTA)
#
# Credentials are taken from the DNS_PROVIDER block above.

# CERT_RENEWAL=true

# Required when CERT_RENEWAL=true. ACME account contact; Let's Encrypt sends
# expiry warnings here.
# CERT_ACME_EMAIL=

# Override to LE staging while testing (rate limits relaxed, certs untrusted):
# CERT_ACME_DIRECTORY=https://acme-staging-v02.api.letsencrypt.org/directory

# Renew this many days before expiry. Must be shorter than cert validity
# (currently 90 days for LE; LE has signaled future moves to shorter terms).
# CERT_RENEWAL_DAYS_BEFORE_EXPIRY=30

# One-shot operator override: bypass the 24-hour rate-limit guard. Use only
# after a cert revocation or compromise. Reset to false after the next renewal.
# CERT_FORCE_REISSUE=false

# The provisioner publishes apex A/AAAA records whenever it manages DNS —
# i.e. when CERT_RENEWAL=true, when with-mta + DNS_PROVIDER is set, or when
# EDGE_PROFILE=cloudflare. PUBLIC_IPV4 is required in all three cases; the
# provisioner refuses to start without it. PUBLIC_IPV6 is optional; if
# previously set and now unset, AAAA records are deleted (delete-on-unset,
# no stale-IP foot-gun).
# PUBLIC_IPV4=
# PUBLIC_IPV6=

# ---------------- Edge / CDN fronting (optional) ----------------
#
# Front the public :443 endpoint with a CDN / reverse proxy. See docs/deployment/edge.md.
#   none        (default) direct-to-origin, no fronting.
#   cloudflare  orange-cloud the apex through Cloudflare. Requires
#               DNS_PROVIDER=cloudflare and PUBLIC_IPV4 (the origin address CF
#               proxies the apex A record to). Add `with-edge` to COMPOSE_PROFILES.
#   generic     any other trusted reverse proxy that sets a real-IP header;
#               requires EDGE_TRUSTED_CIDRS + EDGE_REALIP_HEADER.
# EDGE_PROFILE=none

# Cloudflare golden path:
#   DNS_PROVIDER=cloudflare
#   PUBLIC_IPV4=203.0.113.10
#   EDGE_PROFILE=cloudflare
#   COMPOSE_PROFILES=with-mta,with-edge
# Then lock the host firewall to allow :443 ONLY from Cloudflare's published
# ranges -- that firewall, not Authenticated Origin Pull, is the real lockdown.

# generic profile only. CIDR(s) allowed to set the real-IP header
# (comma/space/tab/newline-separated) and the header name to trust.
# EDGE_TRUSTED_CIDRS=
# EDGE_REALIP_HEADER=X-Real-IP

# cloudflare profile only. Require Cloudflare Authenticated Origin Pull (mTLS
# against CF's origin-pull CA). Defaults to true. NOTE: that CA is CF-GLOBAL --
# AOP proves "reached us via Cloudflare", NOT "via your zone". Ignored, and
# REJECTED if set, under any non-cloudflare profile.
# EDGE_CF_AUTHENTICATED_ORIGIN_PULL=true

# cloudflare profile only. Opt in to postern auto-enabling Cloudflare's zone-level
# ECH setting so the front publishes ech=. OFF by default: it is ZONE-WIDE, needs a
# Zone Settings:Edit CF token, and ECH can break clients on hostile networks.
# Postern only ever turns it ON; it never reverts it.
# EDGE_CF_MANAGE_ZONE_ECH=false

# Auto-manage Cloudflare's zone SSL/TLS mode so CF reaches the origin over HTTPS
# (prevents the Flexible-zone ERR_TOO_MANY_REDIRECTS loop). On by default under
# EDGE_PROFILE=cloudflare; zone-WIDE, so set false to manage it yourself on a shared
# zone. See docs/deployment/edge.md.
# EDGE_CF_MANAGE_SSL_MODE=true
# Target mode to raise to (full|strict). Default strict validates the origin cert.
# EDGE_CF_SSL_MODE=strict

# ---------------- ECH (client SNI concealment, optional) ----------------
#
# ECH mode is PER-CONNECTION: `postern connection add --ech never|auto|always`.
#   auto   -- (default) opportunistic: use ECH if the front serves it, else plaintext.
#   always -- FAIL-CLOSED: refuse to connect if ECH is unavailable.
#   never  -- never attempt ECH. Escape hatch for networks that drop ECH ClientHellos.
# auto/always need ECH_DOH_URL (the DoH resolver the plugin uses to fetch the ECH config).
# See docs/deployment/edge.md.
# ECH_DOH_URL=https://cloudflare-dns.com/dns-query
