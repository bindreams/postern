{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "registryAliases": {
    "dhi.io": "dhi.io"
  },
  "customManagers": [
    {
      "description": "Tag-pinned git-subrepos (e.g. shadowsocks-rust at v1.24.0). Renovate bumps 'branch = vX.Y.Z' to the newest upstream release; .github/workflows/subrepo-pull.yaml completes the pull.",
      "customType": "regex",
      "managerFilePatterns": ["/^external/.*/\\.gitrepo$/"],
      "matchStrings": [
        "remote = https://github.com/(?<depName>[^\\n]+?)(\\.git)?\\n[\\s\\S]*?branch = (?<currentValue>v[\\d.]+)"
      ],
      "datasourceTemplate": "github-releases"
    },
    {
      "description": "Branch-pinned git-subrepos (e.g. v2ray-plugin on master; upstream stopped cutting releases in 2022). Renovate bumps 'commit = <sha>' when the branch moves; .github/workflows/subrepo-pull.yaml completes the pull.",
      "customType": "regex",
      "managerFilePatterns": ["/^external/.*/\\.gitrepo$/"],
      "matchStrings": [
        "remote = (?<packageName>https://github.com/[^\\n]+?)(\\.git)?\\n[\\s\\S]*?branch = (?<currentValue>(?:[^v\\s][^\\s]*|v(?:[^\\d.\\s]|\\d+[^\\d.\\s])[^\\s]*|v))\\s*\\n\\s*commit = (?<currentDigest>[a-f0-9]+)"
      ],
      "datasourceTemplate": "git-refs",
      "versioningTemplate": "loose",
      "depNameTemplate": "{{packageName}}"
    }
  ],
  "hostRules": [
    {
      "matchHost": "dhi.io",
      "hostType": "docker",
      "username": "{{ secrets.DOCKERHUB_USERNAME }}",
      "password": "{{ secrets.DOCKERHUB_TOKEN }}"
    }
  ]
}
