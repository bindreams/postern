error_log /var/log/nginx/error.log warn;
worker_processes auto;

events {}

http {
	server_tokens off;
	include mime.types;
	resolver 127.0.0.11 valid=5s; # Docker DNS, short TTL for container IP changes

	map $http_upgrade $connection_upgrade {
		default upgrade;
		'' close;
	}

	limit_req_zone $binary_remote_addr zone=auth:1m rate=10r/m;

	# Real client IP recovery (PROXY protocol v2). Generated by render.sh from
	# PROXY_PROTOCOL_FROM; empty (no-op) unless that env var is set, so direct
	# deployments are unaffected. Also fixes $binary_remote_addr in the limit_req
	# zone above when behind a passthrough gateway. See docs/gateway.md. (#98)
	include conf.d/real_ip.conf;

	# MTA-STS policy endpoint =====
	include conf.d/mta-sts.conf;

	# Portal + new path-based VPN routing =====
	server {
		server_name ${DOMAIN};
		include conf.d/ssl.conf;
		include conf.d/cert.conf;
		# Edge/CDN real-IP recovery + optional Cloudflare Authenticated Origin
		# Pull mTLS. Generated by render.sh from EDGE_*; empty (no-op) unless
		# EDGE_PROFILE is set. In BOTH :443 blocks so origin-auth covers every
		# TLS handshake on 443. See docs/edge.md.
		include conf.d/edge.conf;
		listen 443 ssl fastopen=256 so_keepalive=on${PROXY_PROTOCOL_LISTEN};
		listen [::]:443 ssl fastopen=256 so_keepalive=on${PROXY_PROTOCOL_LISTEN};

		# HSTS must be re-added here (nginx add_header inheritance is broken
		# when any add_header is used in the same block as an include that also uses add_header)
		add_header Strict-Transport-Security "max-age=63072000; includeSubDomains" always;
		add_header X-Content-Type-Options "nosniff" always;
		add_header X-Frame-Options "DENY" always;
		add_header Content-Security-Policy "default-src 'self'" always;
		add_header Referrer-Policy "no-referrer" always;
		add_header Permissions-Policy "camera=(), microphone=(), geolocation=()" always;

		# VPN tunnel endpoints (path-based, WebSocket only, no logs) -----
		location ~ "^/t/([a-f0-9]{24})$" {
			# Non-WS (418) and dead/unresolvable upstreams (502/503/504) all fall through
			# to @miss, so a /t/ miss is body-identical to a generic 404. (A dead-token WS
			# upgrade still costs one extra resolver round-trip -- a timing-only residual
			# we accept.) Only a live token yields a 101 upgrade.
			error_page 418 502 503 504 = @miss;

			if ($http_upgrade != "websocket") {
				return 418;
			}

			proxy_pass http://ss-$1;
			proxy_redirect off;
			proxy_http_version 1.1;
			proxy_read_timeout 1d;
			proxy_send_timeout 1d;
			proxy_buffering off;
			proxy_request_buffering off;
			proxy_socket_keepalive on;

			proxy_set_header Upgrade $http_upgrade;
			proxy_set_header Connection $connection_upgrade;

			proxy_set_header Host $http_host;
			proxy_set_header X-Real-IP $remote_addr;
			proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

			access_log off;
		}

		# Auth endpoints (rate limited) -----
		location /login {
			limit_req zone=auth burst=5 nodelay;

			proxy_pass http://portal:8000;
			proxy_set_header Host $host;
			proxy_set_header X-Real-IP $remote_addr;
			proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
			proxy_set_header X-Forwarded-Proto $scheme;
		}

		location = /login/verify {
			limit_req zone=auth burst=5 nodelay;

			proxy_pass http://portal:8000;
			proxy_set_header Host $host;
			proxy_set_header X-Real-IP $remote_addr;
			proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
			proxy_set_header X-Forwarded-Proto $scheme;
		}

		# Portal (all other paths) -----
		location / {
			proxy_pass http://portal:8000;
			proxy_set_header Host $host;
			proxy_set_header X-Real-IP $remote_addr;
			proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
			proxy_set_header X-Forwarded-Proto $scheme;
		}

		# Unknown-path / dead-tunnel fallthrough so a /t/ miss looks like any other miss. -----
		location @miss {
			proxy_pass http://portal:8000;
			proxy_set_header Host $host;
			proxy_set_header X-Real-IP $remote_addr;
			proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
			proxy_set_header X-Forwarded-Proto $scheme;
		}
	}

	# Catch-all 404 =====
	server {
		include conf.d/ssl.conf;
		include conf.d/cert.conf;
		include conf.d/edge.conf;
		listen 443 default_server ssl;
		listen [::]:443 default_server ssl;

		return 404;
	}

	# HTTP -> HTTPS redirect =====
	server {
		listen 80 default_server;
		listen [::]:80 default_server;

		return 308 https://$host$request_uri;
	}
}
