# Compose profiles: built-in MTA on by default. Comment to opt out and set
# SMTP_HOST below to a third-party relay (Resend, SES, Mailgun, etc.).
COMPOSE_PROFILES=with-mta

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# (The portal refuses to start if this is left as the placeholder.)
SECRET_KEY=REPLACE_WITH_HEX_STRING

# SMTP target. Default points at the built-in mta service. To use a third-party
# relay, comment COMPOSE_PROFILES above and set the variables below to your
# provider. See docs/mta.md for examples.
SMTP_HOST=mta
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Postern VPN <noreply@postern.example.com>

# Uncomment when re-hosting to a different domain; overrides the default in settings.py
# DOMAIN=postern.example.com

# Built-in MTA refuses to start if required DNS records are missing or wrong.
# Set to false in dev / CI only.
MTA_VERIFY_DNS=true

# REQUIRED in production: technical reports (postmaster, abuse, tls-rpt, bounces)
# are forwarded here. Use a real mailbox you read (Proton, Fastmail, etc.).
# Postern does not host an inbox.
MTA_ADMIN_EMAIL=

# DNSSEC enforcement on the sending domain. Set to:
#   auto  (default) -- probe at startup. If the domain is DNSSEC-signed,
#                      mta refuses to start when the AD bit is missing.
#                      If the domain is unsigned, the check is skipped.
#                      Either way Unbound still validates at runtime for DANE.
#   true             -- always require. mta refuses to start without DNSSEC,
#                      even on unsigned domains. Use for fail-closed production.
#   false            -- skip the startup check entirely. Use only for dev/CI.
MTA_REQUIRE_DNSSEC=auto

# DKIM rotation runs in the separate `provisioner` container, isolated from the
# public-facing mta. Set MTA_DNS_PROVIDER to a libdns provider name (cloudflare,
# route53, gandi, digitalocean, ovh, hetzner, linode, namecheap) plus that
# provider's native env vars below to enable automatic rotation. Leave as "none"
# for manual rotation only -- in that case the provisioner generates the initial
# DKIM keypair on first start, then exits cleanly.
MTA_DKIM_ROTATION_DAYS=180
MTA_DNS_PROVIDER=none
# Provider-specific credentials -- pick the set matching MTA_DNS_PROVIDER above.
# CLOUDFLARE_API_TOKEN=
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# GANDI_API_TOKEN=
# DO_AUTH_TOKEN=
